# Production redirect URLs (must match Cognito app client settings)
VITE_LOGIN_REDIRECT=https://www.darwin.one/loggedin/
VITE_LOGOUT_REDIRECT=https://www.darwin.one/

# Strava OAuth — public Client ID only (visible in the OAuth URL by design; safe to commit).
# The Client Secret is NOT stored here: it is injected at build time from
# ~/.darwin-credentials/deploy_config.sh (export VITE_STRAVA_CLIENT_SECRET) via
# scripts/darwin-deploy.sh, and lives in Darwin/.env.development.local for local dev.
# History: the secret was committed here in 3a5832c, hit GitHub secret scanning, and
# was rotated + removed in 4392019 — do not re-add it. (req #2858)
VITE_STRAVA_CLIENT_ID=92672

